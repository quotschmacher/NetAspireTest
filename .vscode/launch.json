{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "HelloAspire.AppHost",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/HelloAspire/HelloAspire.AppHost/bin/Debug/net10.0/HelloAspire.AppHost.dll",
      "cwd": "${workspaceFolder}/HelloAspire/HelloAspire.AppHost",
      "env": {
        "ASPNETCORE_URLS": "http://localhost:15268",
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_ENVIRONMENT": "Development",
        "ASPIRE_ALLOW_UNSECURED_TRANSPORT": "true",
        "ASPIRE_DASHBOARD_OTLP_ENDPOINT_URL": "http://localhost:19255",
        "ASPIRE_DASHBOARD_MCP_ENDPOINT_URL": "http://localhost:18258",
        "ASPIRE_RESOURCE_SERVICE_ENDPOINT_URL": "http://localhost:20080"
      },
      "console": "internalConsole",
      "stopAtEntry": false
    }
  ]
}
